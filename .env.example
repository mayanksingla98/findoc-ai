# ──────────────────────────────────────────────
# LLM Configuration
# ──────────────────────────────────────────────
# Which LLM provider to use: openai | anthropic | gemini | grok
LLM_PROVIDER=gemini
# Default model for complex tasks (RAG, agents, extraction)
# openai: gpt-4o | anthropic: claude-sonnet-4-20250514 | gemini: gemini-2.0-flash | grok: grok-3-mini
DEFAULT_MODEL=gemini-2.5-flash-preview-05-20
# Only one free model available on free tier — use same for both
CHEAP_MODEL=gemini-2.5-flash-preview-05-20

# OpenAI API key — required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
# Anthropic API key — required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Google Gemini API key — required if LLM_PROVIDER=gemini (free tier available at aistudio.google.com)
GEMINI_API_KEY=
# xAI API key — required if LLM_PROVIDER=grok (get one at console.x.ai)
XAI_API_KEY=

# ──────────────────────────────────────────────
# Embeddings Configuration
# ──────────────────────────────────────────────
# Which embedding provider to use: openai | cohere
EMBEDDING_PROVIDER=openai
# Embedding model to use
EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────
# Vector Database Configuration
# ──────────────────────────────────────────────
# Which vector DB to use: pgvector | qdrant | pinecone | milvus
VECTOR_DB=pgvector
# PostgreSQL connection string (used by pgvector adapter and migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/findoc
# Qdrant URL — required if VECTOR_DB=qdrant
QDRANT_URL=http://localhost:6333
# Pinecone credentials — required if VECTOR_DB=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=
# Milvus URL — required if VECTOR_DB=milvus
MILVUS_URL=

# ──────────────────────────────────────────────
# Queue (BullMQ + Redis)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Observability (Langfuse)
# ──────────────────────────────────────────────
# Langfuse public key for tracing
LANGFUSE_PUBLIC_KEY=
# Langfuse secret key for tracing
LANGFUSE_SECRET_KEY=
# Langfuse host URL
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
# Port the Fastify server listens on
PORT=3000
# Environment: development | production
NODE_ENV=development

# ──────────────────────────────────────────────
# Route defaults
# ──────────────────────────────────────────────
# System prompt prepended to every /chat request unless overridden in the request body
DEFAULT_CHAT_SYSTEM_PROMPT=You are a helpful financial document assistant. Answer concisely and cite figures from the provided context when available.
