{
  "name": "findoc-ai",
  "version": "0.1.0",
  "description": "Production-grade financial document intelligence API",
  "main": "dist/api/index.js",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "tsx db/reset.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:up:all": "docker-compose --profile app up -d",
    "setup": "npm install && npm run docker:up && echo '✓ Ready — run: npm run dev'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/swagger": "^9.7.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/community": "^0.3.43",
    "@langchain/langgraph": "^0.2.71",
    "@scalar/fastify-api-reference": "^1.55.3",
    "bullmq": "^5.52.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.6.1",
    "langfuse": "^3.38.20",
    "openai": "^4.98.0",
    "pg": "^8.16.0",
    "pgvector": "^0.2.0",
    "pino": "^9.6.0",
    "zod": "^3.25.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/pg": "^8.15.4",
    "eslint": "^9.27.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
